DEF PACKAGE_BOX Solid {  
  translation -8.0 6.0 0.35  
  rotation 0 0 1 0  
  children [  
    Shape {  
      appearance PBRAppearance {  
        baseColor 0.8 0.6 0.4  
        roughness 0.7  
        metalness 0  
      }  
      geometry Box {  
        size 0.2 0.2 0.2  
      }  
    }  
  ]  
  name "PACKAGE_BOX"  
  boundingObject Box {  
    size 0.2 0.2 0.2  
  }  
  physics Physics {  
    density -1  
    mass 0.001  
  }  
}  
  
# Remove connectors from drone definitions - keep original Mavic2Pro:  
DEF DRONE1 Mavic2Pro {  
  translation 0 0 0.1  
  rotation 0 0 1 3.141590777218456  
  name "Drone1"  
  controller "tashi_drone"  
  cameraSlot [  
    Camera {  
      width 400  
      height 240  
      near 0.2  
    }  
  ]  
}  
  
DEF DRONE2 Mavic2Pro {  
  translation 2.6 -1.7 0.1  
  rotation 0 0 1 3.141590777218456  
  name "Drone2"  
  controller "tashi_drone"  
}

Robot {
  translation 0 0 0.01
  name "XopsSupervisor"
  controller "xops_supervisor"
  supervisor TRUE
}

Robot {
  translation 0 0 0.01
  name "TashiServer"
  controller "tashi_server"
}
