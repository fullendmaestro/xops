WorldInfo {
  info [
    "XOPS City World"
    "SquareManhole pads are used as pickup, dropoff and home waypoints"
  ]
  title "XOPS City"
  basicTimeStep 8
  defaultDamping Damping {
    linear 0.5
    angular 0.5
  }
}

DEF MAIN_VIEWPOINT Viewpoint {
  orientation 0.22133529479118095 0.054899405638403255 -0.9736518426927515 2.716613632390834
  position 10.881735250785358 -14.96674925809007 13.892678643846055
  fieldOfView 0.55
  near 0.2
  follow "Drone1"
  followType "Pan and Tilt Shot"
  followSmoothness 0.2
}

TexturedBackground {
  luminosity 2.5
}

TexturedBackgroundLight {
}

Floor {
  size 120 120
  tileSize 6 6
  appearance SandyGround {
  }
}


DEF PAD_PICKUP_ALPHA SquareManhole {
  translation -8.0 6.0 -0.03
  name "pad_pickup_alpha"
}

